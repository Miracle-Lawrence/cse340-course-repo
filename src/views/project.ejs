<%- include('partials/header') %>

<main>
  <h1><%= project.title %></h1>

  <p><strong>Description:</strong></p>
  <p><%= project.description %></p>

  <p><strong>Date:</strong> <%= project.date %></p>
  <p><strong>Location:</strong> <%= project.location %></p>

  
  <p>
    <strong>Organization:</strong>
    <a href="/organization/<%= project.organization_id %>">
      <%= project.organization_name %>
    </a>
  </p>

  <% if (user && user.role_name === 'admin') { %>
    <a href="/edit-project/<%= project.project_id %>" class="edit-btn">
  ✏️ Edit Project
  </a>
<% } %>
  

  <!-- Categories as clickable tags -->
  <% if (categories.length > 0) { %>
    <p><strong>Categories:</strong>
      <% categories.forEach(category => { %>
        <a href="/category/<%= category.category_id %>" class="category-tag"><%= category.name %></a>
      <% }) %>
    </p>
  <% } %>

  <br>
  <a href="/projects">← Back to Projects</a>

  <% if (user && user.role_name === 'admin') { %>
      <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
<% } %>

<% if (user) { %>

  <% if (isVolunteer) { %>
    <p>You are volunteering for this project</p>

    <form method="POST" action="/projects/<%= project.project_id %>/unvolunteer">
      <button type="submit">Remove Me</button>
    </form>

  <% } else { %>
    <form method="POST" action="/projects/<%= project.project_id %>/volunteer">
      <button type="submit">Volunteer</button>
    </form>
    
  <% } %>

<% } %>

    
</main>

<%- include('partials/footer') %>