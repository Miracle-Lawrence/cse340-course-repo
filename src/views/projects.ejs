<%- include ('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <h2>Upcoming Service Projects</h2>
 <ul>
    <% projects.forEach(project => { %>
      <li>
        <span class="date"><%= new Date(project.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>:</span>
        <span class="project-title"><%= project.title %></span>
        (<span class="organization-name"><%= project.name %></span>)
      </li>
    <% }) %>
  </ul>
    </main>
<%- include('partials/footer') %>